---
import Analytics from "@vercel/analytics/astro";
import {
  absoluteSiteUrl,
  DEFAULT_SITE_DESCRIPTION,
  SITE_NAME,
  SITE_SOCIAL_IMAGE,
} from "../lib/site";

interface Props {
  title?: string;
  description?: string;
  canonicalPath?: string;
  noindex?: boolean;
}

const {
  title = SITE_NAME,
  description = DEFAULT_SITE_DESCRIPTION,
  canonicalPath = Astro.url.pathname,
  noindex = false,
} = Astro.props;

const canonicalUrl = absoluteSiteUrl(canonicalPath);
const socialImageUrl = absoluteSiteUrl(SITE_SOCIAL_IMAGE);
const robotsContent = noindex ? "noindex,follow" : "index,follow";
const websiteStructuredData = {
  "@context": "https://schema.org",
  "@type": "WebSite",
  name: SITE_NAME,
  url: absoluteSiteUrl("/"),
  description: DEFAULT_SITE_DESCRIPTION,
};
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="robots" content={robotsContent} />
    <meta name="application-name" content={SITE_NAME} />
    <meta name="apple-mobile-web-app-title" content={SITE_NAME} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalUrl} />
    <meta property="og:site_name" content={SITE_NAME} />
    <meta property="og:image" content={socialImageUrl} />
    <meta property="og:image:alt" content="Threadlines app icon" />
    <meta property="og:image:width" content="1024" />
    <meta property="og:image:height" content="1024" />
    <meta name="twitter:card" content="summary" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={socialImageUrl} />
    <meta name="theme-color" content="#09090b" />
    <link rel="canonical" href={canonicalUrl} />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Hanken+Grotesk:wght@400;500;600;700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link rel="icon" href="/favicon.ico" sizes="48x48" />
    <link rel="icon" type="image/png" href="/favicon-32x32.png" sizes="32x32" />
    <link rel="icon" type="image/png" href="/favicon-16x16.png" sizes="16x16" />
    <link rel="apple-touch-icon" href="/apple-touch-icon.png" />
    <title>{title}</title>
    <script is:inline type="application/ld+json" set:html={JSON.stringify(websiteStructuredData)} />
    <Analytics />
  </head>
  <body>
    <div class="page">
      <nav class="nav">
        <div class="nav-inner">
          <a href="/" class="nav-brand" aria-label="Threadlines home">
            <svg class="nav-brand-glyph" viewBox="36 86 184 100" fill="none" aria-hidden="true">
              <defs>
                <linearGradient
                  id="nav-glyph-live"
                  gradientUnits="userSpaceOnUse"
                  x1="108"
                  y1="98"
                  x2="194"
                  y2="162"
                >
                  <stop offset="0" stop-color="#a1a1aa" stop-opacity="0.45"></stop>
                  <stop offset="1" stop-color="var(--accent-bright)"></stop>
                </linearGradient>
              </defs>
              <g stroke-linecap="round" stroke-width="10">
                <path d="M 44 98 L 212 98" stroke="rgba(255, 255, 255, 0.32)"></path>
                <path
                  d="M 108 98 C 134 98 134 162 160 162 L 188 162"
                  stroke="url(#nav-glyph-live)"></path>
              </g>
              <g fill="rgba(255, 255, 255, 0.45)">
                <circle cx="70" cy="98" r="7"></circle>
                <circle cx="108" cy="98" r="8.5"></circle>
                <circle cx="178" cy="98" r="7"></circle>
              </g>
              <circle cx="194" cy="162" r="21" fill="var(--accent-bright)" opacity="0.16"></circle>
              <circle cx="194" cy="162" r="12.5" fill="var(--accent-bright)"></circle>
            </svg>
            <span class="nav-brand-name">Threadlines</span>
          </a>
          <div class="nav-right">
            <a
              class="nav-gh"
              href="https://github.com/Threadlines/threadlines"
              target="_blank"
              rel="noopener noreferrer"
            >
              <svg width="14" height="14" viewBox="0 0 24 24" fill="currentColor" aria-hidden="true">
                <path d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 007.86 10.93c.58.1.79-.25.79-.56v-2c-3.2.69-3.88-1.37-3.88-1.37-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.68 1.25 3.33.96.1-.75.4-1.25.72-1.54-2.55-.29-5.24-1.27-5.24-5.67 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.45.11-3.02 0 0 .96-.31 3.15 1.18a10.96 10.96 0 015.74 0c2.19-1.49 3.15-1.18 3.15-1.18.62 1.57.23 2.73.11 3.02.74.8 1.18 1.83 1.18 3.08 0 4.41-2.7 5.38-5.27 5.66.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.56A11.5 11.5 0 0023.5 12C23.5 5.65 18.35.5 12 .5z"/>
              </svg>
              <span>GitHub</span>
            </a>
            <a class="nav-dl" href="/download"><svg width="13" height="13" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><path d="M12 4v11m0 0l-4.5-4.5M12 15l4.5-4.5M4.5 19.5h15"/></svg><span>Download</span></a>
          </div>
        </div>
      </nav>

      <main class="main">
        <slot />
      </main>

      <footer class="footer">
        <div class="footer-inner">
          <div class="footer-brand">
            <span>&copy; {new Date().getFullYear()} Threadlines</span>
          </div>
          <div class="footer-links">
            <a href="https://github.com/Threadlines/threadlines" target="_blank" rel="noopener noreferrer">GitHub</a>
          </div>
        </div>
      </footer>
    </div>
  </body>
</html>

<style is:global>
  :root {
    --bg: #09090b;
    --bg-elev: #0c0c0e;
    --bg-card: #111113;
    --fg: #fafafa;
    --fg-muted: #a1a1aa;
    --fg-dim: #71717a;
    --fg-faint: #52525b;
    --border: rgba(255, 255, 255, 0.08);
    --border-strong: rgba(255, 255, 255, 0.14);
    --accent-h: 264;
    --accent: oklch(0.62 0.19 var(--accent-h));
    --accent-bright: oklch(0.7 0.17 var(--accent-h));
    --accent-dim: oklch(0.62 0.19 var(--accent-h) / 0.14);
    --ok: oklch(0.72 0.16 150);
    --warn: oklch(0.76 0.15 75);
    --font-sans: "Hanken Grotesk", -apple-system, BlinkMacSystemFont, system-ui, sans-serif;
    --font-mono: "JetBrains Mono", ui-monospace, SFMono-Regular, Menlo, Monaco, monospace;
    --radius: 12px;
    --radius-sm: 8px;
    --radius-lg: 16px;
  }

  * {
    box-sizing: border-box;
    margin: 0;
    padding: 0;
  }

  html {
    color-scheme: dark;
    scroll-behavior: smooth;
  }

  body {
    background: var(--bg);
    color: var(--fg);
    font-family: var(--font-sans);
    -webkit-font-smoothing: antialiased;
    -moz-osx-font-smoothing: grayscale;
    min-height: 100vh;
    overflow-x: clip;
    line-height: 1.5;
  }

  body::after {
    content: "";
    position: fixed;
    inset: 0;
    pointer-events: none;
    opacity: 0.035;
    background-image: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='n'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.9' numOctaves='4' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23n)'/%3E%3C/svg%3E");
    background-repeat: repeat;
    background-size: 256px 256px;
    z-index: 9999;
  }

  a {
    color: inherit;
    text-decoration: none;
  }

  img,
  svg {
    display: block;
    max-width: 100%;
  }

  .eyebrow {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: var(--fg-dim);
    font-weight: 500;
  }

  .display {
    font-weight: 600;
    letter-spacing: -0.035em;
    line-height: 1.04;
  }

  .container {
    width: 100%;
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
  }

  :focus-visible {
    outline: 2px solid var(--accent);
    outline-offset: 2px;
    border-radius: 4px;
  }
</style>

<style>
  .page {
    min-height: 100vh;
    display: flex;
    flex-direction: column;
    overflow-x: clip;
  }

  .nav {
    position: sticky;
    top: 0;
    z-index: 50;
    backdrop-filter: blur(18px);
    -webkit-backdrop-filter: blur(18px);
    background: color-mix(in srgb, var(--bg) 75%, transparent);
  }

  .nav-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 18px 32px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    gap: 24px;
  }

  .nav-brand {
    display: inline-flex;
    align-items: center;
    gap: 9px;
    color: var(--fg);
    transition: color 0.2s ease;
  }

  .nav-brand:hover {
    color: #fff;
  }

  /* The glyph's accent node stands in for the wordmark's period — never both. */
  .nav-brand-glyph {
    height: 15px;
    width: auto;
    display: block;
  }

  .nav-brand-name {
    font-size: 17px;
    font-weight: 650;
    letter-spacing: -0.03em;
    line-height: 1;
  }

  .nav-right {
    display: inline-flex;
    align-items: center;
    gap: 8px;
  }

  .nav-gh {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 7px 12px;
    border: 1px solid var(--border);
    border-radius: 8px;
    color: var(--fg-muted);
    font-family: var(--font-mono);
    font-size: 12px;
    transition: color 0.2s ease, background 0.2s ease, border-color 0.2s ease;
  }

  .nav-gh:hover {
    color: var(--fg);
    background: rgba(255, 255, 255, 0.04);
    border-color: var(--border-strong);
  }

  .nav-dl {
    display: inline-flex;
    align-items: center;
    gap: 7px;
    padding: 7px 14px;
    border-radius: 8px;
    background: var(--accent-bright);
    color: #0b0d10;
    font-size: 13px;
    font-weight: 600;
    transition: transform 0.2s ease, filter 0.2s ease;
  }

  .nav-dl:hover {
    transform: translateY(-1px);
    filter: brightness(1.08);
  }

  .nav-dl svg {
    width: 13px;
    height: 13px;
  }

  .main {
    flex: 1;
    display: flex;
    flex-direction: column;
  }

  .footer {
    margin-top: auto;
    border-top: 1px solid var(--border);
    padding: 28px 0;
  }

  .footer-inner {
    max-width: 1100px;
    margin: 0 auto;
    padding: 0 32px;
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
    align-items: center;
    justify-content: space-between;
  }

  .footer-brand {
    font-size: 13px;
    color: var(--fg-dim);
  }

  .footer-links {
    display: flex;
    gap: 20px;
  }

  .footer-links a {
    font-size: 13px;
    color: var(--fg-dim);
    transition: color 0.2s ease;
  }

  .footer-links a:hover {
    color: var(--fg);
  }

  @media (max-width: 820px) {
    .nav-inner,
    .footer-inner {
      padding-left: 20px;
      padding-right: 20px;
    }

    .nav-gh span {
      display: none;
    }
  }
</style>
