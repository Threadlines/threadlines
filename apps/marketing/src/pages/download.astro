---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Download — Threadlines"
  description="Threadlines downloads open with the public release."
>
  <section class="dl-holding">
    <div class="container dl-inner">
      <h1 class="display dl-title">Downloads open with the public release.</h1>
      <p class="dl-sub">
        Threadlines is in private development. When the repository goes public,
        installers for macOS, Windows, and Linux will land here along with the
        source.
      </p>
      <div class="dl-actions">
        <a class="dl-link" href="/">Back to Threadlines</a>
        <span class="dl-sep" aria-hidden="true">·</span>
        <a
          class="dl-link"
          href="https://github.com/Threadlines"
          target="_blank"
          rel="noopener noreferrer">watch github.com/Threadlines</a
        >
      </div>
    </div>
  </section>
</Layout>

<style>
  .dl-holding {
    flex: 1;
    display: flex;
    align-items: center;
    padding: 64px 0 96px;
  }

  .dl-inner {
    text-align: center;
  }

  .dl-title {
    font-size: clamp(30px, 4.4vw, 52px);
    max-width: 22ch;
    margin: 0 auto 18px;
    text-wrap: balance;
  }

  .dl-sub {
    color: var(--fg-muted);
    font-size: 17px;
    line-height: 1.6;
    max-width: 520px;
    margin: 0 auto 32px;
    text-wrap: pretty;
  }

  .dl-actions {
    display: inline-flex;
    align-items: center;
    gap: 12px;
    font-family: var(--font-mono);
    font-size: 13px;
  }

  .dl-sep {
    color: var(--fg-faint);
  }

  .dl-link {
    color: var(--fg-dim);
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.18);
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .dl-link:hover {
    color: var(--fg);
  }
</style>
