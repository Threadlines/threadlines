---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="Download Threadlines"
  description="Download Threadlines for macOS, Windows, and Linux. Free and open source."
  canonicalPath="/download/"
  noindex
>
  <section class="dl-holding">
    <div class="container dl-inner">
      <h1 class="display dl-title">Download Threadlines</h1>
      <p class="dl-sub" id="dl-version">Fetching the latest release…</p>

      <div class="dl-primary-wrap">
        <a class="dl-primary" id="dl-primary" href="#" hidden>
          <span class="dl-ico" id="dl-ico-mac"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.152 6.896c-.948 0-2.415-1.078-3.96-1.04-2.04.027-3.91 1.183-4.961 3.014-2.117 3.675-.546 9.103 1.519 12.09 1.013 1.454 2.208 3.09 3.792 3.039 1.52-.065 2.09-.987 3.935-.987 1.831 0 2.35.987 3.96.948 1.637-.026 2.676-1.48 3.676-2.948 1.156-1.688 1.636-3.325 1.662-3.415-.039-.013-3.182-1.221-3.22-4.857-.026-3.04 2.48-4.494 2.597-4.559-1.429-2.09-3.623-2.324-4.39-2.376-2-.156-3.675 1.09-4.61 1.09zM15.53 3.83c.843-1.012 1.4-2.427 1.245-3.83-1.207.052-2.662.805-3.532 1.818-.78.896-1.454 2.338-1.273 3.714 1.338.104 2.715-.688 3.559-1.701"/></svg></span>
          <span class="dl-ico" id="dl-ico-win" hidden><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 3h8.5v8.5H3zM12.5 3H21v8.5h-8.5zM3 12.5h8.5V21H3zM12.5 12.5H21V21h-8.5z"/></svg></span>
          <span class="dl-ico" id="dl-ico-linux" hidden><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M4 3h16a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm2.94 4.3 4 3.06a.9.9 0 0 1 0 1.43l-4 3.06a.9.9 0 1 1-1.1-1.43L9 11.07 5.84 8.73A.9.9 0 1 1 6.94 7.3ZM12.5 14.4h4.7a.9.9 0 1 1 0 1.8h-4.7a.9.9 0 1 1 0-1.8Z"/></svg></span>
          <span id="dl-primary-label">Download</span>
          <span class="dl-primary-size" id="dl-primary-size"></span>
        </a>
      </div>

      <div class="dl-list" id="dl-list" hidden>
        <div class="dl-row" data-slot="macArm">
          <span class="dl-row-name"><span class="dl-row-ico"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.152 6.896c-.948 0-2.415-1.078-3.96-1.04-2.04.027-3.91 1.183-4.961 3.014-2.117 3.675-.546 9.103 1.519 12.09 1.013 1.454 2.208 3.09 3.792 3.039 1.52-.065 2.09-.987 3.935-.987 1.831 0 2.35.987 3.96.948 1.637-.026 2.676-1.48 3.676-2.948 1.156-1.688 1.636-3.325 1.662-3.415-.039-.013-3.182-1.221-3.22-4.857-.026-3.04 2.48-4.494 2.597-4.559-1.429-2.09-3.623-2.324-4.39-2.376-2-.156-3.675 1.09-4.61 1.09zM15.53 3.83c.843-1.012 1.4-2.427 1.245-3.83-1.207.052-2.662.805-3.532 1.818-.78.896-1.454 2.338-1.273 3.714 1.338.104 2.715-.688 3.559-1.701"/></svg></span>macOS · Apple Silicon</span>
          <span class="dl-row-size"></span>
          <a class="dl-link" href="#">Download .dmg</a>
        </div>
        <div class="dl-row" data-slot="macX64">
          <span class="dl-row-name"><span class="dl-row-ico"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.152 6.896c-.948 0-2.415-1.078-3.96-1.04-2.04.027-3.91 1.183-4.961 3.014-2.117 3.675-.546 9.103 1.519 12.09 1.013 1.454 2.208 3.09 3.792 3.039 1.52-.065 2.09-.987 3.935-.987 1.831 0 2.35.987 3.96.948 1.637-.026 2.676-1.48 3.676-2.948 1.156-1.688 1.636-3.325 1.662-3.415-.039-.013-3.182-1.221-3.22-4.857-.026-3.04 2.48-4.494 2.597-4.559-1.429-2.09-3.623-2.324-4.39-2.376-2-.156-3.675 1.09-4.61 1.09zM15.53 3.83c.843-1.012 1.4-2.427 1.245-3.83-1.207.052-2.662.805-3.532 1.818-.78.896-1.454 2.338-1.273 3.714 1.338.104 2.715-.688 3.559-1.701"/></svg></span>macOS · Intel</span>
          <span class="dl-row-size"></span>
          <a class="dl-link" href="#">Download .dmg</a>
        </div>
        <div class="dl-row" data-slot="winX64">
          <span class="dl-row-name"><span class="dl-row-ico"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 3h8.5v8.5H3zM12.5 3H21v8.5h-8.5zM3 12.5h8.5V21H3zM12.5 12.5H21V21h-8.5z"/></svg></span>Windows · x64</span>
          <span class="dl-row-size"></span>
          <a class="dl-link" href="#">Download .exe</a>
        </div>
        <div class="dl-row" data-slot="winArm">
          <span class="dl-row-name"><span class="dl-row-ico"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 3h8.5v8.5H3zM12.5 3H21v8.5h-8.5zM3 12.5h8.5V21H3zM12.5 12.5H21V21h-8.5z"/></svg></span>Windows · ARM64</span>
          <span class="dl-row-size"></span>
          <a class="dl-link" href="#">Download .exe</a>
        </div>
        <div class="dl-row" data-slot="linuxX64">
          <span class="dl-row-name"><span class="dl-row-ico"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path fill-rule="evenodd" d="M4 3h16a2 2 0 0 1 2 2v14a2 2 0 0 1-2 2H4a2 2 0 0 1-2-2V5a2 2 0 0 1 2-2Zm2.94 4.3 4 3.06a.9.9 0 0 1 0 1.43l-4 3.06a.9.9 0 1 1-1.1-1.43L9 11.07 5.84 8.73A.9.9 0 1 1 6.94 7.3ZM12.5 14.4h4.7a.9.9 0 1 1 0 1.8h-4.7a.9.9 0 1 1 0-1.8Z"/></svg></span>Linux · x64</span>
          <span class="dl-row-size"></span>
          <a class="dl-link" href="#">Download .AppImage</a>
        </div>
      </div>

      <div id="dl-fallback" hidden>
        <div class="dl-panel">
          <p class="dl-panel-kicker">Direct downloads</p>
          <p class="dl-panel-text">
            GitHub's API didn't answer just now. No problem: every installer is one click
            away on the releases page.
          </p>
          <a
            class="dl-primary"
            href="https://github.com/Threadlines/threadlines/releases"
            target="_blank"
            rel="noopener noreferrer"><span class="dl-ico"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12 .5C5.65.5.5 5.65.5 12a11.5 11.5 0 007.86 10.93c.58.1.79-.25.79-.56v-2c-3.2.69-3.88-1.37-3.88-1.37-.52-1.33-1.27-1.69-1.27-1.69-1.04-.71.08-.7.08-.7 1.15.08 1.76 1.18 1.76 1.18 1.02 1.76 2.68 1.25 3.33.96.1-.75.4-1.25.72-1.54-2.55-.29-5.24-1.27-5.24-5.67 0-1.25.45-2.28 1.18-3.08-.12-.29-.51-1.45.11-3.02 0 0 .96-.31 3.15 1.18a10.96 10.96 0 015.74 0c2.19-1.49 3.15-1.18 3.15-1.18.62 1.57.23 2.73.11 3.02.74.8 1.18 1.83 1.18 3.08 0 4.41-2.7 5.38-5.27 5.66.41.36.78 1.06.78 2.13v3.16c0 .31.21.67.8.56A11.5 11.5 0 0023.5 12C23.5 5.65 18.35.5 12 .5z"/></svg></span>Download from GitHub</a
          >
          <div class="dl-panel-rows">
            <span><i>›</i> macOS · Apple Silicon and Intel · <code>.dmg</code></span>
            <span><i>›</i> Windows · x64 · <code>.exe</code></span>
            <span><i>›</i> Linux · x64 · <code>.AppImage</code></span>
          </div>
        </div>
      </div>

      <noscript>
        <p class="dl-sub">
          Grab any installer from
          <a class="dl-link" href="https://github.com/Threadlines/threadlines/releases"
            >GitHub Releases</a
          >.
        </p>
      </noscript>

      <p class="dl-note">
        Signed and notarized for macOS · Signed for Windows · AppImage for Linux · All releases and checksums on&nbsp;<a
          class="dl-link"
          href="https://github.com/Threadlines/threadlines/releases"
          target="_blank"
          rel="noopener noreferrer">GitHub</a
        >
      </p>
    </div>
  </section>
</Layout>

<script>
  import { classifyAssets, fetchLatestRelease, formatAssetSize } from "../lib/releases";

  const versionEl = document.getElementById("dl-version")!;
  const primary = document.getElementById("dl-primary") as HTMLAnchorElement;
  const primaryLabel = document.getElementById("dl-primary-label")!;
  const primarySize = document.getElementById("dl-primary-size")!;
  const list = document.getElementById("dl-list")!;
  const fallback = document.getElementById("dl-fallback")!;

  const platform = (
    (navigator as { userAgentData?: { platform?: string } }).userAgentData?.platform ||
    navigator.platform ||
    ""
  ).toLowerCase();
  const isWindows = platform.includes("win");
  const isMac = platform.includes("mac");
  const isLinux = platform.includes("linux");

  try {
    const release = await fetchLatestRelease();
    const installers = classifyAssets(release.assets);

    versionEl.textContent = `Latest release: ${release.tag_name}`;

    const rows = list.querySelectorAll<HTMLElement>(".dl-row");
    let anyRow = false;
    for (const row of rows) {
      const asset = installers[row.dataset.slot as keyof typeof installers];
      if (!asset) {
        row.hidden = true;
        continue;
      }
      anyRow = true;
      row.querySelector(".dl-row-size")!.textContent = formatAssetSize(asset.size);
      row.querySelector("a")!.href = asset.browser_download_url;
    }
    list.hidden = !anyRow;

    const primaryAsset = isWindows
      ? (installers.winX64 ?? installers.winArm)
      : isLinux
        ? installers.linuxX64
        : (installers.macArm ?? installers.macX64);
    if (primaryAsset && (isMac || isWindows || isLinux)) {
      primary.href = primaryAsset.browser_download_url;
      document.getElementById("dl-ico-mac")!.hidden = !isMac;
      document.getElementById("dl-ico-win")!.hidden = !isWindows;
      document.getElementById("dl-ico-linux")!.hidden = !isLinux;
      primaryLabel.textContent = isWindows
        ? "Download for Windows"
        : isLinux
          ? "Download for Linux"
          : "Download for macOS";
      primarySize.textContent = formatAssetSize(primaryAsset.size);
      primary.hidden = false;
    }

    if (!anyRow) throw new Error("No installers in release");
  } catch {
    versionEl.textContent = "Free and open source · macOS, Windows, and Linux";
    primary.hidden = true;
    list.hidden = true;
    fallback.hidden = false;
  }
</script>

<style>
  .dl-holding {
    flex: 1;
    display: flex;
    align-items: center;
    padding: 64px 0 96px;
  }

  .dl-inner {
    text-align: center;
  }

  .dl-title {
    font-size: clamp(30px, 4.4vw, 52px);
    max-width: 22ch;
    margin: 0 auto 18px;
    text-wrap: balance;
  }

  .dl-sub {
    color: var(--fg-muted);
    font-size: 17px;
    line-height: 1.6;
    max-width: 520px;
    margin: 0 auto 28px;
    text-wrap: pretty;
  }

  .dl-primary-wrap {
    margin-bottom: 36px;
  }

  .dl-primary {
    display: inline-flex;
    align-items: baseline;
    gap: 10px;
    background: var(--accent-bright);
    color: var(--accent-contrast);
    font-weight: 600;
    border-radius: 10px;
    padding: 12px 22px;
    text-decoration: none;
    transition: transform 0.2s ease;
  }

  .dl-primary:hover {
    transform: translateY(-1px);
  }

  .dl-primary[hidden] {
    display: none;
  }

  .dl-primary-size {
    font-size: 0.8rem;
    font-weight: 500;
    opacity: 0.7;
  }

  .dl-ico {
    display: inline-flex;
    align-self: center;
  }

  .dl-ico[hidden] {
    display: none;
  }

  .dl-ico svg {
    width: 16px;
    height: 16px;
  }

  .dl-row-name {
    display: inline-flex;
    align-items: center;
    gap: 9px;
  }

  .dl-row-ico {
    display: inline-flex;
    color: var(--fg-dim);
  }

  .dl-row-ico svg {
    width: 14px;
    height: 14px;
  }

  .dl-list {
    max-width: 460px;
    margin: 0 auto 32px;
    border: 1px solid var(--border);
    border-radius: 12px;
    overflow: hidden;
  }

  .dl-row {
    display: grid;
    grid-template-columns: 1fr auto auto;
    gap: 16px;
    align-items: center;
    padding: 12px 18px;
    text-align: left;
    font-size: 14px;
  }

  .dl-row + .dl-row {
    border-top: 1px solid var(--border);
  }

  .dl-row-name {
    color: var(--fg);
  }

  .dl-row-size {
    color: var(--fg-dim);
    font-family: var(--font-mono);
    font-size: 12px;
  }

  .dl-panel {
    position: relative;
    max-width: 480px;
    margin: 0 auto 32px;
    padding: 28px 32px 30px;
    border: 1px solid var(--border);
    border-radius: 14px;
    background:
      radial-gradient(closest-side at 75% 0%, var(--accent-dim), transparent 70%),
      var(--surface);
    overflow: hidden;
  }

  .dl-panel-kicker {
    font-family: var(--font-mono);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: var(--accent-bright);
    margin-bottom: 10px;
  }

  .dl-panel-text {
    color: var(--fg-muted);
    font-size: 15px;
    line-height: 1.6;
    margin-bottom: 22px;
    text-wrap: pretty;
  }

  .dl-panel-rows {
    display: grid;
    gap: 6px;
    margin-top: 22px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-dim);
    text-align: left;
    justify-content: center;
  }

  .dl-panel-rows i {
    font-style: normal;
    color: var(--accent-bright);
    opacity: 0.7;
    margin-right: 6px;
  }

  .dl-panel-rows code {
    color: var(--fg-muted);
  }

  .dl-note {
    color: var(--fg-dim);
    font-size: 13px;
  }

  .dl-link {
    color: var(--fg-dim);
    text-decoration: underline;
    text-decoration-color: var(--underline);
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .dl-link:hover {
    color: var(--fg);
  }
</style>
