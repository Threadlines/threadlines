---
import Layout from "../layouts/Layout.astro";
import { absoluteSiteUrl, DEFAULT_SITE_DESCRIPTION } from "../lib/site";

const L = "/Screenshots/launch";

const appStructuredData = {
  "@context": "https://schema.org",
  "@type": "SoftwareApplication",
  name: "Threadlines",
  operatingSystem: "macOS, Windows",
  applicationCategory: "DeveloperApplication",
  offers: { "@type": "Offer", price: "0", priceCurrency: "USD" },
  description: DEFAULT_SITE_DESCRIPTION,
  url: absoluteSiteUrl("/"),
  downloadUrl: absoluteSiteUrl("/download"),
  license: "https://opensource.org/license/mit/",
  sameAs: ["https://github.com/Threadlines/threadlines", "https://x.com/threadlinesdev"],
};

const contextClips = [
  {
    name: "chat-highlight-note",
    tab: "01 · Note on a reply",
    label:
      "Highlighting a sentence of the assistant's reply, adding a note, attaching it to the composer, then reopening and editing the saved note",
  },
  {
    name: "code-selection-to-chat",
    tab: "02 · Code lines",
    label: "Selecting a range of code lines in the file viewer and attaching it to the chat composer",
  },
  {
    name: "terminal-selection-to-chat",
    tab: "03 · Terminal lines",
    label:
      "Selecting lines of real terminal output, attaching them to the composer, and reopening the exact-line preview",
  },
];

const playGlyphs = `<svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="pv-ico-play"><path d="M8 5.2v13.6L19 12z"/></svg><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true" class="pv-ico-pause"><path d="M7 5h3.6v14H7zM13.4 5H17v14h-3.6z"/></svg>`;
---

<Layout
  title="Threadlines: a local workspace for coding agents"
  description="Run Claude Code and Codex in parallel threads with real source control, live usage meters, and full visibility into every task, subagent, and background run."
  canonicalPath="/"
  structuredData={[appStructuredData]}
>
  <section class="pv-hero">
    <div class="pv-glow pv-glow-hero" aria-hidden="true"></div>
    <div class="pv-wrap">
      <svg
        class="pv-figure"
        viewBox="0 48 960 152"
        fill="none"
        role="img"
        aria-label="A git graph of agent threads: branches diverge from a main line and merge back; one branch stays open, ending in a glowing node"
      >
        <defs>
          <linearGradient
            id="pv-live-stroke"
            gradientUnits="userSpaceOnUse"
            x1="432"
            y1="128"
            x2="816"
            y2="180"
          >
            <stop offset="0" stop-color="#a1a1aa" stop-opacity="0.35"></stop>
            <stop offset="1" stop-color="var(--accent-bright)" stop-opacity="0.9"></stop>
          </linearGradient>
        </defs>
        <g stroke-linecap="round" stroke-width="1.25">
          <path
            class="pv-line" vector-effect="non-scaling-stroke"
            d="M -8 128 L 968 128"
            pathLength="1"
            stroke="var(--line-dim)"
            style="--pv-delay: 0.2s"></path>
          <path
            class="pv-line" vector-effect="non-scaling-stroke"
            d="M 256 128 C 282 128 282 76 308 76 L 600 76 C 626 76 626 128 652 128"
            pathLength="1"
            stroke="var(--line-faint)"
            style="--pv-delay: 0.7s; animation-duration: 0.8s"></path>
          <path
            class="pv-line" vector-effect="non-scaling-stroke"
            d="M 432 128 C 458 128 458 180 484 180 L 812 180"
            pathLength="1"
            stroke="url(#pv-live-stroke)"
            style="--pv-delay: 0.95s; animation-duration: 0.8s"></path>
        </g>
        <g fill="var(--node)">
          <circle class="pv-node" cx="140" cy="128" r="3" style="--pv-delay: 0.45s"></circle>
          <circle class="pv-node" cx="256" cy="128" r="3.5" style="--pv-delay: 0.6s"></circle>
          <circle class="pv-node" cx="432" cy="128" r="3.5" style="--pv-delay: 0.8s"></circle>
          <circle class="pv-node" cx="452" cy="76" r="3" style="--pv-delay: 1.2s"></circle>
          <circle class="pv-node" cx="652" cy="128" r="3.5" style="--pv-delay: 1.4s"></circle>
          <circle class="pv-node" cx="744" cy="128" r="3" style="--pv-delay: 1.3s"></circle>
          <circle class="pv-node" cx="896" cy="128" r="3" style="--pv-delay: 1.5s"></circle>
        </g>
        <circle class="pv-halo" cx="816" cy="180" r="6" fill="var(--accent-bright)"></circle>
        <circle
          class="pv-node pv-node-live"
          cx="816"
          cy="180"
          r="4"
          fill="var(--accent-bright)"
          style="--pv-delay: 1.6s"></circle>
      </svg>

      <h1 class="pv-display pv-rise" style="--pv-d: 0.25s">Every thread leaves a line.</h1>
      <p class="pv-sub pv-rise" style="--pv-d: 0.4s">
        Threadlines is a local desktop workspace that runs Claude&nbsp;Code and Codex in
        parallel threads, with <span class="pv-accent">real source control</span> at the
        center and nothing hidden. Bring the subscriptions you already pay for.
      </p>
      <div class="pv-cta-row pv-rise" style="--pv-d: 0.55s">
        <a class="pv-cta pv-cta-primary" id="pv-download" href="/download"><span class="pv-cta-ico" id="pv-dl-mac"><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M12.152 6.896c-.948 0-2.415-1.078-3.96-1.04-2.04.027-3.91 1.183-4.961 3.014-2.117 3.675-.546 9.103 1.519 12.09 1.013 1.454 2.208 3.09 3.792 3.039 1.52-.065 2.09-.987 3.935-.987 1.831 0 2.35.987 3.96.948 1.637-.026 2.676-1.48 3.676-2.948 1.156-1.688 1.636-3.325 1.662-3.415-.039-.013-3.182-1.221-3.22-4.857-.026-3.04 2.48-4.494 2.597-4.559-1.429-2.09-3.623-2.324-4.39-2.376-2-.156-3.675 1.09-4.61 1.09zM15.53 3.83c.843-1.012 1.4-2.427 1.245-3.83-1.207.052-2.662.805-3.532 1.818-.78.896-1.454 2.338-1.273 3.714 1.338.104 2.715-.688 3.559-1.701"/></svg></span><span class="pv-cta-ico" id="pv-dl-win" hidden><svg viewBox="0 0 24 24" fill="currentColor" aria-hidden="true"><path d="M3 3h8.5v8.5H3zM12.5 3H21v8.5h-8.5zM3 12.5h8.5V21H3zM12.5 12.5H21V21h-8.5z"/></svg></span><span id="pv-dl-label">Download for macOS</span></a>
        <a
          class="pv-cta"
          href="https://github.com/Threadlines/threadlines"
          target="_blank"
          rel="noopener noreferrer">View on GitHub</a
        >
      </div>
      <p class="pv-note pv-rise" style="--pv-d: 0.7s">
        Free and open source (MIT) · No account · Your code never leaves your machine
      </p>
      <div class="pv-providers pv-rise" style="--pv-d: 0.8s" aria-label="Supported agents">
        <span class="pv-providers-label">Runs the agents you already use</span>
        <span class="pv-provider">
          <svg viewBox="0 0 256 260" preserveAspectRatio="xMidYMid" aria-hidden="true"><path fill="currentColor" d="M239.184 106.203a64.716 64.716 0 0 0-5.576-53.103C219.452 28.459 191 15.784 163.213 21.74A65.586 65.586 0 0 0 52.096 45.22a64.716 64.716 0 0 0-43.23 31.36c-14.31 24.602-11.061 55.634 8.033 76.74a64.665 64.665 0 0 0 5.525 53.102c14.174 24.65 42.644 37.324 70.446 31.36a64.72 64.72 0 0 0 48.754 21.744c28.481.025 53.714-18.361 62.414-45.481a64.767 64.767 0 0 0 43.229-31.36c14.137-24.558 10.875-55.423-8.083-76.483Zm-97.56 136.338a48.397 48.397 0 0 1-31.105-11.255l1.535-.87 51.67-29.825a8.595 8.595 0 0 0 4.247-7.367v-72.85l21.845 12.636c.218.111.37.32.409.563v60.367c-.056 26.818-21.783 48.545-48.601 48.601Zm-104.466-44.61a48.345 48.345 0 0 1-5.781-32.589l1.534.921 51.722 29.826a8.339 8.339 0 0 0 8.441 0l63.181-36.425v25.221a.87.87 0 0 1-.358.665l-52.335 30.184c-23.257 13.398-52.97 5.431-66.404-17.803ZM23.549 85.38a48.499 48.499 0 0 1 25.58-21.333v61.39a8.288 8.288 0 0 0 4.195 7.316l62.874 36.272-21.845 12.636a.819.819 0 0 1-.767 0L41.353 151.53c-23.211-13.454-31.171-43.144-17.804-66.405v.256Zm179.466 41.695-63.08-36.63L161.73 77.86a.819.819 0 0 1 .768 0l52.233 30.184a48.6 48.6 0 0 1-7.316 87.635v-61.391a8.544 8.544 0 0 0-4.4-7.213Zm21.742-32.69-1.535-.922-51.619-30.081a8.39 8.39 0 0 0-8.492 0L99.98 99.808V74.587a.716.716 0 0 1 .307-.665l52.233-30.133a48.652 48.652 0 0 1 72.236 50.391v.205ZM88.061 139.097l-21.845-12.585a.87.87 0 0 1-.41-.614V65.685a48.652 48.652 0 0 1 79.757-37.346l-1.535.87-51.67 29.825a8.595 8.595 0 0 0-4.246 7.367l-.051 72.697Zm11.868-25.58 28.138-16.217 28.188 16.218v32.434l-28.086 16.218-28.188-16.218-.052-32.434Z"/></svg>
          Codex
        </span>
        <span class="pv-provider">
          <svg viewBox="0 0 256 257" aria-hidden="true"><path fill="#d97757" d="m50.228 170.321 50.357-28.257.843-2.463-.843-1.361h-2.462l-8.426-.518-28.775-.778-24.952-1.037-24.175-1.296-6.092-1.297L0 125.796l.583-3.759 5.12-3.434 7.324.648 16.202 1.101 24.304 1.685 17.629 1.037 26.118 2.722h4.148l.583-1.685-1.426-1.037-1.101-1.037-25.147-17.045-27.22-18.017-14.258-10.37-7.713-5.25-3.888-4.925-1.685-10.758 7-7.713 9.397.649 2.398.648 9.527 7.323 20.35 15.75L94.817 91.9l3.889 3.24 1.555-1.102.195-.777-1.75-2.917-14.453-26.118-15.425-26.572-6.87-11.018-1.814-6.61c-.648-2.723-1.102-4.991-1.102-7.778l7.972-10.823L71.42 0 82.05 1.426l4.472 3.888 6.61 15.101 10.694 23.786 16.591 32.34 4.861 9.592 2.592 8.879.973 2.722h1.685v-1.556l1.36-18.211 2.528-22.36 2.463-28.776.843-8.1 4.018-9.722 7.971-5.25 6.222 2.981 5.12 7.324-.713 4.73-3.046 19.768-5.962 30.98-3.889 20.739h2.268l2.593-2.593 10.499-13.934 17.628-22.036 7.778-8.749 9.073-9.657 5.833-4.601h11.018l8.1 12.055-3.628 12.443-11.342 14.388-9.398 12.184-13.48 18.147-8.426 14.518.778 1.166 2.01-.194 30.46-6.481 16.462-2.982 19.637-3.37 8.88 4.148.971 4.213-3.5 8.62-20.998 5.184-24.628 4.926-36.682 8.685-.454.324.519.648 16.526 1.555 7.065.389h17.304l32.21 2.398 8.426 5.574 5.055 6.805-.843 5.184-12.962 6.611-17.498-4.148-40.83-9.721-14-3.5h-1.944v1.167l11.666 11.406 21.387 19.314 26.767 24.887 1.36 6.157-3.434 4.86-3.63-.518-23.526-17.693-9.073-7.972-20.545-17.304h-1.36v1.814l4.73 6.935 25.017 37.59 1.296 11.536-1.814 3.76-6.481 2.268-7.13-1.297-14.647-20.544-15.1-23.138-12.185-20.739-1.49.843-7.194 77.448-3.37 3.953-7.778 2.981-6.48-4.925-3.436-7.972 3.435-15.749 4.148-20.544 3.37-16.333 3.046-20.285 1.815-6.74-.13-.454-1.49.194-15.295 20.999-23.267 31.433-18.406 19.702-4.407 1.75-7.648-3.954.713-7.064 4.277-6.286 25.47-32.405 15.36-20.092 9.917-11.6-.065-1.686h-.583L44.07 198.125l-12.055 1.555-5.185-4.86.648-7.972 2.463-2.593 20.35-13.999-.064.065Z"/></svg>
          Claude Code
        </span>
      </div>
    </div>
    <figure class="pv-app-frame pv-rise" style="--pv-d: 0.95s">
      <div
        class="pv-frame pv-expand"
        role="button"
        tabindex="0"
        aria-label="Expand the workspace demo"
      >
        <video
          class="pv-video"
          muted
          playsinline
          loop
          preload="metadata"
          poster={`${L}/Posters/rich-subagent-chat.webp`}
          width="3200"
          height="1868"
          aria-label="Scrolling through a Threadlines conversation where a Scout subagent's full findings render as a first-class message, with the source control panel and commit graph beside the thread"
        >
          <source src={`${L}/rich-subagent-chat.webm`} type="video/webm" />
          <source src={`${L}/rich-subagent-chat.mp4`} type="video/mp4" />
        </video>
        <button class="pv-play" type="button" aria-label="Play video" hidden set:html={playGlyphs} />
      </div>
      <figcaption>
        A subagent reporting back, with source control one panel away.
      </figcaption>
    </figure>
  </section>

  <section class="pv-section">
    <div class="pv-wrap pv-center pv-reveal">
      <p class="pv-kicker">Project files, first-class</p>
      <h2>The project is part of the conversation</h2>
      <p class="pv-lede">
        The project-file popover is a real file surface: tabs, browsing, and syntax
        highlighting. Open a file, edit it, save it, without leaving the thread. Then
        select the lines that matter and attach them to the chat as exact context.
      </p>
    </div>
    <div class="pv-showcase pv-reveal pv-reveal-late">
      <div
        class="pv-frame pv-expand"
        role="button"
        tabindex="0"
        aria-label="Expand the project files demo"
      >
        <video
          class="pv-video"
          muted
          playsinline
          loop
          preload="none"
          poster={`${L}/Posters/project-files-edit.webp`}
          width="1600"
          height="934"
          aria-label="Browsing project files in tabs with syntax highlighting, editing and saving a file, selecting lines, and attaching them to the chat"
        >
          <source src={`${L}/project-files-edit.webm`} type="video/webm" />
          <source src={`${L}/project-files-edit.mp4`} type="video/mp4" />
        </video>
        <button class="pv-play" type="button" aria-label="Play video" hidden set:html={playGlyphs} />
      </div>
    </div>
  </section>

  <section class="pv-section">
    <div class="pv-wrap pv-feature">
      <div class="pv-copy pv-reveal">
        <p class="pv-kicker">One thread, two providers</p>
        <h2>Hit a usage limit? Switch, don't stop.</h2>
        <p>
          Switch a running conversation between Claude and Codex in place. The recap and
          your working tree carry over. Live meters show both providers' five-hour and
          weekly windows with reset countdowns, so you see the wall before you hit it and
          keep shipping when you do.
        </p>
      </div>
      <div class="pv-media pv-reveal pv-reveal-late" data-tabset>
        <div
          class="pv-frame pv-frame-fit pv-expand"
          role="button"
          tabindex="0"
          aria-label="Expand the provider switching screenshots"
        >
          <img
            class="pv-pane pv-active"
            src="/Screenshots/switch-dialog.png"
            alt="Switch to Codex dialog explaining that Codex picks up a recap of the conversation and the current working tree"
            loading="lazy"
          />
          <img
            class="pv-pane"
            src="/Screenshots/providers-usage.png"
            alt="Provider settings showing Codex and Claude subscriptions side by side with live five-hour and weekly usage meters and reset countdowns"
            loading="lazy"
          />
        </div>
        <div class="pv-steps" role="tablist" aria-label="Provider switching views">
          <button class="pv-step pv-active" role="tab" aria-selected="true" type="button"
            >01 · Switch in place</button
          >
          <button class="pv-step" role="tab" aria-selected="false" type="button"
            >02 · Live meters</button
          >
        </div>
      </div>
    </div>
  </section>

  <section class="pv-section">
    <div class="pv-wrap pv-center pv-reveal">
      <p class="pv-kicker">Steer, don't re-prompt</p>
      <h2>Reply to the exact lines you mean</h2>
      <p class="pv-lede">
        Select a sentence of the agent's answer, a range of code, or lines of terminal
        output, and attach exactly that to your next message. Add a note when you attach
        it, then reopen or edit the note from the composer before you send.
        Course-correct in seconds instead of writing paragraphs of follow-up.
      </p>
    </div>
    <div class="pv-showcase pv-reveal pv-reveal-late" data-tabset>
      <div
        class="pv-frame pv-expand"
        role="button"
        tabindex="0"
        aria-label="Expand the exact-context demo"
      >
        {
          contextClips.map((c, i) => (
            <video
              class:list={["pv-video", "pv-pane", i === 0 && "pv-active"]}
              muted
              playsinline
              loop
              preload="none"
              poster={`${L}/Posters/${c.name}.webp`}
              width="1600"
              height="934"
              aria-label={c.label}
            >
              <source src={`${L}/${c.name}.webm`} type="video/webm" />
              <source src={`${L}/${c.name}.mp4`} type="video/mp4" />
            </video>
          ))
        }
        <button class="pv-play" type="button" aria-label="Play video" hidden set:html={playGlyphs} />
      </div>
      <div class="pv-steps" role="tablist" aria-label="Exact-context flows">
        {
          contextClips.map((c, i) => (
            <button
              class:list={["pv-step", i === 0 && "pv-active"]}
              role="tab"
              aria-selected={i === 0 ? "true" : "false"}
              type="button"
            >
              {c.tab}
            </button>
          ))
        }
      </div>
    </div>
  </section>

  <section class="pv-section">
    <div class="pv-wrap pv-center pv-reveal">
      <p class="pv-kicker">Nothing runs invisibly</p>
      <h2>Every task, subagent, and background run. Visible, labeled, stoppable.</h2>
      <p class="pv-lede">
        The activity header shows what your agents are actually doing: a task list with
        live states, each subagent's goal with the model and effort it runs on, and
        background processes with a Stop button. And when a subagent finishes, its
        findings land in the conversation the way you saw at the top of this page, not
        as a collapsed spinner line.
      </p>
    </div>
    <div class="pv-showcase pv-reveal pv-reveal-late">
      <div
        class="pv-frame pv-expand"
        role="button"
        tabindex="0"
        aria-label="Expand the activity header demo"
      >
        <video
          class="pv-video"
          data-theme-swap
          data-clip="activity-header-dark"
          muted
          playsinline
          loop
          preload="none"
          poster={`${L}/Posters/activity-header-dark.webp`}
          width="3200"
          height="1868"
          aria-label="Threadlines with the activity dropdown open: a six-item task list with four done, two subagents with model and reasoning-effort labels, and a background release preview with a Stop button"
        >
          <source src={`${L}/activity-header-dark.webm`} type="video/webm" />
          <source src={`${L}/activity-header-dark.mp4`} type="video/mp4" />
        </video>
        <button class="pv-play" type="button" aria-label="Play video" hidden set:html={playGlyphs} />
      </div>
      <p class="pv-theme-note">
        This capture follows the site theme — try the toggle in the top bar.
      </p>
    </div>
  </section>

  <section class="pv-section">
    <div class="pv-wrap">
      <div class="pv-reveal pv-center">
        <p class="pv-kicker">Built to be boring</p>
        <h2>Reliability is the feature</h2>
      </div>
      <div class="pv-grid">
        <div class="pv-card pv-reveal">
          <h3>Survives restarts</h3>
          <p>Sessions resume across app and server restarts via event replay. Close the lid mid-turn and pick it back up.</p>
        </div>
        <div class="pv-card pv-reveal" style="--pv-d: 0.08s">
          <h3>Fork from anywhere</h3>
          <p>Fork any message into a parallel thread with context, attachments, and working tree included.</p>
        </div>
        <div class="pv-card pv-reveal" style="--pv-d: 0.16s">
          <h3>Worktrees per thread</h3>
          <p>Give each agent its own isolated checkout, or share one. Your call, per thread.</p>
        </div>
        <div class="pv-card pv-card-wide pv-reveal" style="--pv-d: 0.24s">
          <div class="pv-card-wide-copy">
          <h3>Always within reach</h3>
          <p>Glanceable agent status from the macOS menu bar: running threads, one click away.</p>
          </div>
          <video
            class="pv-card-video pv-video"
            muted
            loop
            playsinline
            preload="metadata"
            poster="/Screenshots/menubar-tray.png"
            aria-label="Screen recording of the Threadlines macOS menu bar item showing a running thread count and dropdown"
          >
            <source src="/Screenshots/menubar-animation.webm" type="video/webm" />
            <source src="/Screenshots/menubar-animation.mp4" type="video/mp4" />
          </video>
        </div>
      </div>
    </div>
  </section>

  <section class="pv-section">
    <div class="pv-wrap pv-center pv-reveal">
      <p class="pv-kicker">Source control, not a diff drawer</p>
      <h2>From agent diff to opened PR</h2>
      <p class="pv-lede">
        A real source-control panel sits beside every thread: changes grouped per file
        and folder with staged and unstaged state, per-file review and actions, and a
        one-button generate, commit, and push flow with your hooks' output shown, not
        hidden. GitHub, GitLab, Bitbucket, and Azure DevOps.
      </p>
    </div>
    <div class="pv-showcase pv-reveal pv-reveal-late">
      <h3 class="pv-sublabel"><span>01</span> Changes, file by file</h3>
      <p class="pv-subcopy">
        Step through each changed file's own diff, review and act on it, then return to
        the grouped tree without losing your place.
      </p>
      <div
        class="pv-frame pv-expand"
        role="button"
        tabindex="0"
        aria-label="Expand the per-file source control demo"
      >
        <video
          class="pv-video"
          muted
          playsinline
          loop
          preload="none"
          poster={`${L}/Posters/source-control-by-file.webp`}
          width="1600"
          height="934"
          aria-label="Stepping through changed files one diff at a time, then returning to the grouped source-control tree with staged and unstaged changes"
        >
          <source src={`${L}/source-control-by-file.webm`} type="video/webm" />
          <source src={`${L}/source-control-by-file.mp4`} type="video/mp4" />
        </video>
