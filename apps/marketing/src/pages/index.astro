---
import Layout from "../layouts/Layout.astro";
---

<Layout>
  <section class="teaser">
    <div class="teaser-glow" aria-hidden="true"></div>

    <div class="container teaser-inner">
      <svg
        class="tl-figure"
        viewBox="0 48 960 152"
        fill="none"
        role="img"
        aria-label="A git graph of agent threads: branches diverge from a main line and merge back; one branch stays open, ending in a glowing node"
      >
        <defs>
          <linearGradient
            id="tl-live-stroke"
            gradientUnits="userSpaceOnUse"
            x1="432"
            y1="128"
            x2="816"
            y2="180"
          >
            <stop offset="0" stop-color="#a1a1aa" stop-opacity="0.35"></stop>
            <stop offset="1" stop-color="var(--accent-bright)" stop-opacity="0.9"></stop>
          </linearGradient>
        </defs>
        <g stroke-linecap="round" stroke-width="1.25">
          <path
            class="tl-line" vector-effect="non-scaling-stroke"
            d="M -8 128 L 968 128"
            pathLength="1"
            stroke="rgba(255, 255, 255, 0.17)"
            style="--tl-delay: 0.2s"></path>
          <path
            class="tl-line" vector-effect="non-scaling-stroke"
            d="M 256 128 C 282 128 282 76 308 76 L 600 76 C 626 76 626 128 652 128"
            pathLength="1"
            stroke="rgba(255, 255, 255, 0.12)"
            style="--tl-delay: 0.7s; animation-duration: 0.8s"></path>
          <path
            class="tl-line" vector-effect="non-scaling-stroke"
            d="M 432 128 C 458 128 458 180 484 180 L 812 180"
            pathLength="1"
            stroke="url(#tl-live-stroke)"
            style="--tl-delay: 0.95s; animation-duration: 0.8s"></path>
        </g>
        <g fill="rgba(255, 255, 255, 0.3)">
          <circle class="tl-node" cx="140" cy="128" r="3" style="--tl-delay: 0.45s"></circle>
          <circle class="tl-node" cx="256" cy="128" r="3.5" style="--tl-delay: 0.6s"></circle>
          <circle class="tl-node" cx="432" cy="128" r="3.5" style="--tl-delay: 0.8s"></circle>
          <circle class="tl-node" cx="452" cy="76" r="3" style="--tl-delay: 1.2s"></circle>
          <circle class="tl-node" cx="652" cy="128" r="3.5" style="--tl-delay: 1.4s"></circle>
          <circle class="tl-node" cx="744" cy="128" r="3" style="--tl-delay: 1.3s"></circle>
          <circle class="tl-node" cx="896" cy="128" r="3" style="--tl-delay: 1.5s"></circle>
        </g>
        <circle class="tl-halo" cx="816" cy="180" r="6" fill="var(--accent-bright)"></circle>
        <circle
          class="tl-node tl-node-live"
          cx="816"
          cy="180"
          r="4"
          fill="var(--accent-bright)"
          style="--tl-delay: 1.6s"></circle>
      </svg>

      <h1 class="display t-title t-rise" style="--t-delay: 0.25s">
        Every thread leaves a line.
      </h1>

      <p class="t-sub t-rise" style="--t-delay: 0.4s">
        Threadlines is a desktop workspace that runs coding agents like Claude&nbsp;Code
        and Codex in parallel threads, with real source control at the center. Every
        conversation lands on a branch you can review, commit, and ship.
      </p>

      <div class="t-status t-rise" style="--t-delay: 0.55s">
        <span class="t-status-dot" aria-hidden="true"></span>
        <span>In private development</span>
        <span class="t-status-sep" aria-hidden="true">·</span>
        <a
          class="t-status-link"
          href="https://github.com/Threadlines"
          target="_blank"
          rel="noopener noreferrer">watch github.com/Threadlines</a
        >
      </div>
    </div>
  </section>
</Layout>

<style>
  .teaser {
    flex: 1;
    display: flex;
    align-items: center;
    position: relative;
    overflow: hidden;
    padding: 16px 0 48px;
  }

  .teaser-glow {
    position: absolute;
    top: 18%;
    right: 6%;
    width: 540px;
    height: 420px;
    pointer-events: none;
    background: radial-gradient(closest-side, var(--accent-dim), transparent 72%);
  }

  .teaser-inner {
    position: relative;
    text-align: center;
  }

  .tl-figure {
    width: min(760px, 100%);
    height: auto;
    margin: 0 auto 16px;
  }

  .t-title {
    font-size: clamp(40px, 6.4vw, 78px);
    max-width: 16ch;
    margin: 0 auto 22px;
    text-wrap: balance;
  }

  .t-sub {
    color: var(--fg-muted);
    font-size: clamp(16px, 1.5vw, 19px);
    line-height: 1.6;
    letter-spacing: -0.005em;
    max-width: 620px;
    margin: 0 auto 40px;
    text-wrap: pretty;
  }

  .t-status {
    display: inline-flex;
    align-items: center;
    gap: 10px;
    padding: 9px 16px;
    border: 1px solid var(--border);
    border-radius: 999px;
    font-family: var(--font-mono);
    font-size: 12px;
    color: var(--fg-muted);
  }

  .t-status-dot {
    width: 7px;
    height: 7px;
    border-radius: 999px;
    background: var(--accent-bright);
    flex-shrink: 0;
  }

  .t-status-sep {
    color: var(--fg-faint);
  }

  .t-status-link {
    color: var(--fg-dim);
    text-decoration: underline;
    text-decoration-color: rgba(255, 255, 255, 0.18);
    text-underline-offset: 3px;
    transition: color 0.2s ease;
  }

  .t-status-link:hover {
    color: var(--fg);
  }

  .tl-halo {
    opacity: 0;
    transform-box: fill-box;
    transform-origin: center;
  }

  @media (prefers-reduced-motion: no-preference) {
    .t-rise {
      opacity: 0;
      animation: t-rise 0.8s cubic-bezier(0.22, 1, 0.36, 1) both;
      animation-delay: var(--t-delay, 0s);
    }

    .tl-line {
      stroke-dasharray: 1;
      stroke-dashoffset: 1;
      animation: tl-draw 1.1s cubic-bezier(0.45, 0, 0.2, 1) both;
      animation-delay: var(--tl-delay, 0s);
    }

    .tl-node {
      opacity: 0;
      animation: tl-node-in 0.5s ease-out both;
      animation-delay: var(--tl-delay, 0s);
    }

    .tl-halo {
      animation: tl-halo 3.2s cubic-bezier(0.33, 0, 0.2, 1) infinite;
      animation-delay: 2s;
    }

    .t-status-dot {
      animation: t-status-pulse 3.2s cubic-bezier(0.33, 0, 0.2, 1) infinite;
      animation-delay: 2s;
    }
  }

  @keyframes t-rise {
    from {
      opacity: 0;
      transform: translateY(10px);
    }
    to {
      opacity: 1;
      transform: translateY(0);
    }
  }

  @keyframes tl-draw {
    0% {
      stroke-dashoffset: 1;
      opacity: 0;
    }
    4% {
      opacity: 1;
    }
    100% {
      stroke-dashoffset: 0;
      opacity: 1;
    }
  }

  @keyframes tl-node-in {
    from {
      opacity: 0;
    }
    to {
      opacity: 1;
    }
  }

  @keyframes tl-halo {
    0% {
      opacity: 0.5;
      transform: scale(1);
    }
    70%,
    100% {
      opacity: 0;
      transform: scale(2.4);
    }
  }

  @keyframes t-status-pulse {
    0% {
      box-shadow: 0 0 0 0 oklch(0.7 0.17 var(--accent-h) / 0.45);
    }
    70%,
    100% {
      box-shadow: 0 0 0 9px transparent;
    }
  }

  @media (max-width: 820px) {
    .teaser {
      padding: 24px 0 72px;
    }

    .container {
      padding-left: 20px;
      padding-right: 20px;
    }

    .tl-figure {
      margin-bottom: 8px;
    }

    .t-sub {
      margin-bottom: 32px;
    }

    .t-status {
      flex-wrap: wrap;
      justify-content: center;
      row-gap: 4px;
    }
  }
</style>
