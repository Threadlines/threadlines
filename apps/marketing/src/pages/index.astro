<script>
  import { classifyAssets, fetchLatestRelease } from "../lib/releases";

  const reduced = window.matchMedia("(prefers-reduced-motion: reduce)").matches;

  const dl = document.getElementById("pv-download") as HTMLAnchorElement | null;
  if (dl) {
    const plat = (
      (navigator as { userAgentData?: { platform?: string } }).userAgentData?.platform ||
      navigator.platform ||
      ""
    ).toLowerCase();
    const isWin = plat.includes("win");
    const label = document.getElementById("pv-dl-label")!;
    if (isWin) {
      label.textContent = "Download for Windows";
      document.getElementById("pv-dl-mac")!.hidden = true;
      document.getElementById("pv-dl-win")!.hidden = false;
    } else if (plat.includes("linux")) {
      label.textContent = "Download Threadlines";
      document.getElementById("pv-dl-mac")!.hidden = true;
    }
    if (isWin || plat.includes("mac")) {
      // deep-link the button straight to the installer; /download stays the fallback
      fetchLatestRelease()
        .then((release) => {
          const installers = classifyAssets(release.assets);
          const asset = isWin
            ? (installers.winX64 ?? installers.winArm)
            : (installers.macArm ?? installers.macX64);
          if (asset) dl.href = asset.browser_download_url;
        })
        .catch(() => {});
    }
  }

  const targets = document.querySelectorAll(".pv-reveal");
  if (reduced || !("IntersectionObserver" in window)) {
    for (const el of targets) el.classList.add("pv-in");
  } else {
    const observer = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) {
            entry.target.classList.add("pv-in");
            observer.unobserve(entry.target);
          }
        }
      },
      { threshold: 0.15, rootMargin: "0px 0px -40px 0px" },
    );
    for (const el of targets) observer.observe(el);
  }

  // --- viewport-driven video playback ---------------------------------------
  // Videos only play while on screen, and only the active pane of a tab set.
  // Under reduced motion nothing autoplays; per-frame play buttons take over.
  const inView = new WeakSet<Element>();
  const syncVideo = (v: HTMLVideoElement) => {
    if (reduced) return;
    const activePane = !v.classList.contains("pv-pane") || v.classList.contains("pv-active");
    if (inView.has(v) && activePane) v.play().catch(() => {});
    else v.pause();
  };
  const videos = [...document.querySelectorAll<HTMLVideoElement>("video.pv-video")];
  if (!reduced && "IntersectionObserver" in window) {
    const playObserver = new IntersectionObserver(
      (entries) => {
        for (const entry of entries) {
          if (entry.isIntersecting) inView.add(entry.target);
          else inView.delete(entry.target);
          syncVideo(entry.target as HTMLVideoElement);
        }
      },
      { threshold: 0.25 },
    );
    for (const v of videos) playObserver.observe(v);
  }
  if (reduced) {
    for (const btn of document.querySelectorAll<HTMLButtonElement>(".pv-play")) {
      btn.hidden = false;
      btn.addEventListener("click", (e) => {
        e.stopPropagation();
        const frame = btn.closest<HTMLElement>(".pv-frame")!;
        const video =
          frame.querySelector<HTMLVideoElement>("video.pv-active") ??
          frame.querySelector<HTMLVideoElement>("video");
        if (!video) return;
        if (video.paused) {
          video.play().catch(() => {});
          btn.classList.add("pv-playing");
          btn.setAttribute("aria-label", "Pause video");
        } else {
          video.pause();
          btn.classList.remove("pv-playing");
          btn.setAttribute("aria-label", "Play video");
        }
      });
    }
  }

  // --- tab sets --------------------------------------------------------------
  for (const set of document.querySelectorAll<HTMLElement>("[data-tabset]")) {
    const panes = [...set.querySelectorAll<HTMLElement>(".pv-pane")];
    const steps = [...set.querySelectorAll<HTMLButtonElement>(".pv-step")];
    const select = (i: number) => {
      set.dataset.current = String(i);
      panes.forEach((p, j) => {
        p.classList.toggle("pv-active", i === j);
        if (p instanceof HTMLVideoElement) syncVideo(p);
      });
      steps.forEach((s, j) => {
        s.classList.toggle("pv-active", i === j);
        s.setAttribute("aria-selected", i === j ? "true" : "false");
      });
      const play = set.querySelector<HTMLButtonElement>(".pv-play");
      if (play) {
        play.classList.remove("pv-playing");
        play.setAttribute("aria-label", "Play video");
      }
    };
    steps.forEach((step, i) => step.addEventListener("click", () => select(i)));
  }

  // --- lightbox (images and videos) ------------------------------------------
  const lightbox = document.getElementById("pv-lightbox")!;
  const lbStage = lightbox.querySelector<HTMLElement>(".pv-lightbox-stage")!;
  const lbClose = lightbox.querySelector<HTMLButtonElement>(".pv-lightbox-close")!;
  const lbPrev = lightbox.querySelector<HTMLButtonElement>(".pv-lightbox-prev")!;
  const lbNext = lightbox.querySelector<HTMLButtonElement>(".pv-lightbox-next")!;
  let lbItems: (HTMLImageElement | HTMLVideoElement)[] = [];
  let lbIndex = 0;
  const lbShow = (i: number) => {
    lbIndex = (i + lbItems.length) % lbItems.length;
    const item = lbItems[lbIndex];
    lbStage.replaceChildren();
    if (item instanceof HTMLVideoElement) {
      const video = document.createElement("video");
      video.className = "pv-lightbox-media";
      video.controls = true;
      video.muted = true;
      video.loop = true;
      video.playsInline = true;
      video.poster = item.poster;
      video.setAttribute("aria-label", item.getAttribute("aria-label") ?? "");
      for (const source of item.querySelectorAll("source")) {
        video.append(source.cloneNode());
      }
      lbStage.append(video);
      if (!reduced) video.play().catch(() => {});
    } else {
      const img = document.createElement("img");
      img.className = "pv-lightbox-media";
      img.src = item.currentSrc || item.src;
      img.alt = item.alt;
      lbStage.append(img);
    }
    const solo = lbItems.length < 2;
    lbPrev.hidden = solo;
    lbNext.hidden = solo;
  };
  const lbOpen = (items: (HTMLImageElement | HTMLVideoElement)[], i: number) => {
    if (!items.length) return;
    lbItems = items;
    lbShow(i);
    lightbox.hidden = false;
    document.documentElement.style.overflow = "hidden";
    lbClose.focus();
  };
  const closeLightbox = () => {
    lightbox.hidden = true;
    lbStage.replaceChildren();
    document.documentElement.style.overflow = "";
  };
  lightbox.addEventListener("click", (e) => {
    if (e.target === lightbox) closeLightbox();
  });
  lbClose.addEventListener("click", closeLightbox);
  lbPrev.addEventListener("click", () => lbShow(lbIndex - 1));
  lbNext.addEventListener("click", () => lbShow(lbIndex + 1));
  document.addEventListener("keydown", (e) => {
    if (lightbox.hidden) return;
    if (e.key === "Escape") closeLightbox();
    if (e.key === "ArrowLeft") lbShow(lbIndex - 1);
    if (e.key === "ArrowRight") lbShow(lbIndex + 1);
  });
  let lbWheelAt = 0;
  lightbox.addEventListener(
    "wheel",
    (e) => {
      e.preventDefault();
      if (lbItems.length < 2) return;
      const now = Date.now();
      if (now - lbWheelAt < 350 || Math.abs(e.deltaY) < 12) return;
      lbWheelAt = now;
      lbShow(lbIndex + (e.deltaY > 0 ? 1 : -1));
    },
    { passive: false },
  );

  const wireExpand = (trigger: HTMLElement, open: () => void) => {
    trigger.addEventListener("click", open);
    trigger.addEventListener("keydown", (e) => {
      if (e.key === "Enter" || e.key === " ") {
        e.preventDefault();
        open();
      }
    });
  };
  for (const frame of document.querySelectorAll<HTMLElement>(".pv-frame.pv-expand")) {
    const media = [...frame.querySelectorAll<HTMLImageElement | HTMLVideoElement>("img, video")];
    wireExpand(frame, () => {
      const set = frame.closest<HTMLElement>("[data-tabset]");
      lbOpen(media, set ? Number(set.dataset.current || 0) : 0);
    });
  }

  // --- theme-following capture -----------------------------------------------
  // The activity showcase has a light-theme twin; swap it when the site theme flips.
  const themed = document.querySelector<HTMLVideoElement>("video[data-theme-swap]");
  const applyThemedClip = () => {
    if (!themed) return;
    const name =
      document.documentElement.dataset.theme === "light"
        ? "activity-header-light"
        : "activity-header-dark";
    if (themed.dataset.clip === name) return;
    themed.dataset.clip = name;
    const wasPlaying = !themed.paused;
    themed.poster = `/Screenshots/launch/Posters/${name}.webp`;
    for (const source of themed.querySelectorAll("source")) {
      const ext = source.type === "video/webm" ? "webm" : "mp4";
      source.src = `/Screenshots/launch/${name}.${ext}`;
    }
    themed.load();
    if (wasPlaying) themed.play().catch(() => {});
  };
  document.addEventListener("tl-themechange", applyThemedClip);
  applyThemedClip();
</script>

